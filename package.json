{
  "name": "@maximilianslawik/tbrowser",
  "version": "0.1.0",
  "description": "Full Node.js and npm runtime for the tbrowser local browser control plane",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "tbrowser": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "docker",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:image": "docker build -t tbrowser/browser-base:local -f docker/browser-base/Dockerfile .",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "prepare": "npm run clean && npm run build",
    "pretest": "npm run clean && npm run build",
    "test": "node --test dist/test/**/*.test.js",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "browser",
    "automation",
    "chromium",
    "docker",
    "node",
    "tbrowser"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxSlawik/tbrowser-NPM.git"
  },
  "bugs": {
    "url": "https://github.com/MaxSlawik/tbrowser-NPM/issues"
  },
  "homepage": "https://github.com/MaxSlawik/tbrowser-NPM#readme",
  "license": "MIT",
  "author": "MaxSlawik",
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "dockerode": "^4.0.9",
    "express": "^5.1.0",
    "mime-types": "^3.0.1",
    "tar": "^7.5.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.40",
    "@types/express": "^5.0.3",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.6.1",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
