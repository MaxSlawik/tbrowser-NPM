{
  "name": "tbrowser-npm",
  "version": "0.1.0",
  "description": "Node.js and npm client for the tbrowser local browser control plane",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "tbrowser": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "prepare": "npm run clean && npm run build",
    "pretest": "npm run clean && npm run build",
    "test": "node --test dist/test/**/*.test.js",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "browser",
    "automation",
    "chromium",
    "docker",
    "node",
    "tbrowser"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxSlawik/tbrowser-NPM.git"
  },
  "bugs": {
    "url": "https://github.com/MaxSlawik/tbrowser-NPM/issues"
  },
  "homepage": "https://github.com/MaxSlawik/tbrowser-NPM#readme",
  "license": "MIT",
  "author": "MaxSlawik",
  "dependencies": {
    "mime-types": "^3.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.6.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
